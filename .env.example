# Common
BASE_URL=https://legacy-fantasy.com
REPORT_BUGS_ON_FAILURE=false

# Auth mode
# Default behavior requires no manual login and signs a local admin JWT for test runs.
# Set E2E_AUTH_MODE=device only when you explicitly want live device-flow auth.
# E2E_AUTH_MODE=device
# E2E_TEST_IDENTITY=admin

# Optional live device-flow account credentials used only by legacy/manual flows
GOOGLE_EMAIL=your_google_email@gmail.com
GOOGLE_PASSWORD=your_google_password

# Provider selector
# Supported values: openai, anthropic, xai, openrouter, openai-compatible
QA_AI_PROVIDER=openai
QA_MODEL=gpt-4o-mini

# Optional matrix-only model overrides
ANTHROPIC_QA_MODEL=claude-opus-4-6
XAI_QA_MODEL=grok-4.20-0309-reasoning

# OpenAI (ChatGPT)
OPENAI_API_KEY=
# Optional for OpenAI-compatible gateways/proxies
# OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# xAI (Grok)
XAI_API_KEY=
# Optional
# XAI_BASE_URL=https://api.x.ai/v1

# OpenRouter
OPENROUTER_API_KEY=
# Optional
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_HTTP_REFERER=https://your-app.example
# OPENROUTER_APP_TITLE=ai-qa-agent

# Custom OpenAI-compatible endpoint
# QA_OPENAI_COMPAT_BASE_URL=https://your-provider.example/v1
# QA_OPENAI_COMPAT_API_KEY=your_provider_api_key

# Jira integration
JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_EMAIL=you@your-company.com
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=PROJ
JIRA_ISSUE_TYPE=Bug
